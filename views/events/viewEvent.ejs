<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR Code - <%= produit.name %></title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #4CAF50;
            --secondary-color: #2196F3;
            --text-color: #333;
        }
        
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f5f5f5;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 2rem;
            color: var(--text-color);
        }
        
        .qr-container {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            text-align: center;
            max-width: 500px;
            width: 100%;
        }
        
        h2 {
            color: var(--primary-color);
            margin-bottom: 0.3rem;
        }
        
        .qr-image {
            max-width: 150px;
            width: 50%;
            height: auto;
            margin: 1rem 0;
            border: 1px solid #eee;
            padding: 10px;
        }
        
        .product-info {
            margin-top: 1.5rem;
            padding: 1rem;
            background-color: #f9f9f9;
            border-radius: 8px;
        }
        
        .btn {
            display: inline-block;
            margin: 0.5rem;
            padding: 0.8rem 1.5rem;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }
        
        .btn-primary {
            background-color: #2d302d;
        }
        
        .btn-primary:hover {
            background-color: #2d302d;
            transform: translateY(-2px);
        }
        
        .btn-secondary {
            background-color: var(--secondary-color);
        }
        
        .btn-secondary:hover {
            background-color: #0b7dda;
            transform: translateY(-2px);
        }
        
        .btn-group {
            margin-top: 1.5rem;
        }
    </style>
</head>
<body>
    <div class="qr-container">
        <h2>QR Code du produit</h2>
        
        <div>
            <img src="<%= produit.qrUrl %>" alt="QR Code pour <%= produit.name %>" class="qr-image">
        </div>
        
        <div class="product-info">
            <h3><%= produit.name %></h3>
            <p>UUID: <%= produit.uuid %></p>
            <br>
            <p><%= produit.description %></p>
        </div>
        
        <div class="btn-group">
            <!-- Bouton de téléchargement -->
            <button onclick="downloadQRCode()" class="btn btn-secondary">
                <i class="fas fa-download"></i> Télécharger
            </button>
            
            <a href="/produit/myprod" class="btn btn-primary">
                <i class="fas fa-arrow-left"></i> Retour
            </a>
        </div>
    </div>

    <!-- Script pour le téléchargement -->
    <script>
        function downloadQRCode() {
            // Crée un lien temporaire pour le téléchargement
            const link = document.createElement('a');
            link.href = '<%= produit.qrUrl %>';
            link.download = 'QRCode_<%= produit.name.replace(/ /g, "_") %>_<%= produit.uuid %>.png';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }
    </script>
    
    <!-- Icônes Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
</body>
</html>