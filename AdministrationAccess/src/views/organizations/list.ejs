<%- include('../partials/header') %>

<nav class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
            <div class="flex items-center space-x-8">
                <span class="text-2xl font-bold text-primary">AccessQ Admin</span>
                <div class="hidden md:flex space-x-4">
                    <a href="/dashboard" class="text-slate-500 hover:text-slate-900 px-3 py-2 rounded-md text-sm font-medium">Tableau de bord</a>
                    <a href="/organizations" class="bg-slate-100 text-slate-900 px-3 py-2 rounded-md text-sm font-medium">Organisations</a>
                    <a href="/users" class="text-slate-500 hover:text-slate-900 px-3 py-2 rounded-md text-sm font-medium">Utilisateurs</a>
                </div>
            </div>
            <div class="flex items-center space-x-4">
                <a href="/logout" class="text-slate-500 hover:text-red-600 px-3 py-2 rounded-md text-sm font-medium transition-colors">
                    Déconnexion
                </a>
            </div>
        </div>
    </div>
</nav>

<main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">Gestion des Organisations</h1>
            <p class="text-slate-500 mt-1">Gérez le statut des organisations inscrites sur la plateforme.</p>
        </div>
    </div>

    <% if (error) { %>
        <div class="bg-red-50 text-red-600 p-4 rounded-lg mb-6"><%= error %></div>
    <% } %>
    <% if (success) { %>
        <div class="bg-green-50 text-green-600 p-4 rounded-lg mb-6"><%= success %></div>
    <% } %>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">ID</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Nom</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Statistiques</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Statut</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200">
                    <% organizations.forEach(org => { %>
                        <% if (!org.deleted_at) { %>
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">#<%= org.org_id %></td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-medium text-slate-900"><%= org.name %></div>
                                    <div class="text-sm text-slate-500">Inscrit le <%= new Date(org.created_at).toLocaleDateString('fr-FR') %></div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 mr-2">
                                        <%= org._count.usersQ %> Utilisateurs
                                    </span>
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">
                                        <%= org._count.events %> Événements
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% if (org.is_active) { %>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                            Actif
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                            Désactivé
                                        </span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                                    <% if (org.is_active) { %>
                                        <form action="/organizations/<%= org.org_id %>/deactivate" method="POST" class="inline">
                                            <button type="submit" class="text-yellow-600 hover:text-yellow-900" onclick="return confirm('Voulez-vous vraiment désactiver cette organisation ? Cela désactivera tous ses utilisateurs.')">Désactiver</button>
                                        </form>
                                    <% } else { %>
                                        <form action="/organizations/<%= org.org_id %>/activate" method="POST" class="inline">
                                            <button type="submit" class="text-green-600 hover:text-green-900" onclick="return confirm('Voulez-vous réactiver cette organisation ?')">Réactiver</button>
                                        </form>
                                        <form action="/organizations/<%= org.org_id %>/archive" method="POST" class="inline ml-2">
                                            <button type="submit" class="text-red-600 hover:text-red-900" onclick="return confirm('Attention: L\'archivage (soft delete) est irréversible depuis l\'interface. Continuer ?')">Archiver</button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% } %>
                    <% }) %>
                    <% if (organizations.filter(o => !o.deleted_at).length === 0) { %>
                        <tr>
                            <td colspan="5" class="px-6 py-8 text-center text-slate-500">Aucune organisation trouvée.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
