// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String @unique
  password String

  events Event[]

  @@map("users")
}

model Event {
  id          Int    @id @default(autoincrement())
  name        String
  customer    String
  description String
  userId      Int

  user User @relation(fields: [userId], references: [id])
  qrs  Qr[]

  @@map("events")
}

model Qr {
  id           Int      @id @default(autoincrement())
  projectid    Int
  information  String
  creationdate DateTime @default(now())

  event Event @relation(fields: [projectid], references: [id])

  @@map("qrs")
}
