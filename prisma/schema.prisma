// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  orgId        Int
  fullName     String
  email        String   @unique
  passwordHash String
  role         String   // SUPER_ADMIN, ORG_ADMIN, OPERATOR
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id])
  scanLogs     ScanLog[]

  @@map("users")
}


model Event {
  id          Int      @id @default(autoincrement())
  orgId       Int
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  organization Organization @relation(fields: [orgId], references: [id])
  qrs          Qr[]

  @@map("events")
}


model Qr {
  id          Int      @id @default(autoincrement())
  eventId     Int
  uniqueToken String   @unique
  status      String   // active, revoked, expired, used_up
  usageLimit  Int      
  scansCount  Int      
  validFrom   DateTime
  validUntil  DateTime
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  event    Event
  scanLogs ScanLog[]

  @@map("qr_codes")
}


model Category {
  id       Int    @id @default(autoincrement())
  catname     String @unique
  userId      Int

  usercat User @relation(fields: [userId], references: [id])
  events Event[]
  @@map("categories")
}

model ScanLog {
  id        Int      @id @default(autoincrement())
  qrId      Int
  operatorId Int
  scannedAt DateTime @default(now())
  latitude  Float?
  longitude Float?
  status    String   // authorized, denied_expired, denied_duplicate

  qr       Qr   @relation(fields: [qrId], references: [id])
  operator User @relation(fields: [operatorId], references: [id])

  @@map("scan_logs")
}


model Organization {
  id               Int      @id @default(autoincrement())
  name             String
  subscriptionPlan String   @default("free")
  createdAt        DateTime @default(now())

  users  User[]
  events Event[]

  @@map("organizations")
}
