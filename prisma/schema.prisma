// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model User {
  id       Int      @id @default(autoincrement())
  name     String
  password String

  // Relations
  events   Event[]
}

model Event {
  id         Int      @id @default(autoincrement())
  userId     Int
  name       String
  customer   String
  description String

  // Relations
  user       User     @relation(fields: [userId], references: [id])
  qrs        Qr[]
}

model Qr {
  id           Int      @id @default(autoincrement())
  projectid    Int
  information  String
  creationdate DateTime @default(now())

  // Relation avec Event
  event        Event    @relation(fields: [projectid], references: [id])
}


