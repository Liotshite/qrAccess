// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  ORG_AGENT
  OPERATOR
}

enum QrStatus {
  active
  revoked
  expired
  used_up
}

enum ScanStatus {
  authorized
  denied_expired
  denied_revoked
  denied_limit_reached
}

//////////////////////////////////////////////////
// TABLES
//////////////////////////////////////////////////

model User {
  id            Int       @id @default(autoincrement())
  clef          String    @unique
  full_name     String
  email         String    @unique
  password_hash String
  role          UserRole
  deleted_at    DateTime?
  created_at    DateTime  @default(now())
  last_login    DateTime?

  org_id        Int?
  organization  Organization? @relation(fields: [org_id], references: [id])

  scan_logs     ScanLog[]
}

model Organization {
  id                Int      @id @default(autoincrement())
  name              String
  created_at        DateTime @default(now())
  deleted_at        DateTime?

  subscription_plan Int?
  plan              Plan? @relation(fields: [subscription_plan], references: [id])

  users             User[]
  events            Event[]
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  start_date  DateTime
  end_date    DateTime
  create_at   DateTime @default(now())
  deleted_at  DateTime?

  org_id      Int
  organization Organization @relation(fields: [org_id], references: [id])

  qr_codes    QrCode[]
  deroulements Deroulement[]
  @@index([org_id])
}

model QrCode {
  id            Int      @id @default(autoincrement())
  information   String?
  unique_token  String   @unique
  status        QrStatus
  usage_limit   Int      @default(1)
  scans_count   Int      @default(0)
  valid_from    DateTime?
  valid_until   DateTime?
  deleted_at    DateTime?
  level         Int?

  event_id      Int
  event         Event @relation(fields: [event_id], references: [id])

  scan_logs     ScanLog[]
}

model ScanLog {
  id            Int      @id @default(autoincrement())
  scanned_at    DateTime @default(now())
  location_lat  Float?
  location_long Float?
  status        ScanStatus

  qr_code_id    Int
  qr_code       QrCode @relation(fields: [qr_code_id], references: [id])

  scanned_by_id Int
  scanned_by    User @relation(fields: [scanned_by_id], references: [id])
  
  @@index([qr_code_id])
  }

model Area {
  id                   Int    @id @default(autoincrement())
  area_name            String
  accreditation_level  Int

  deroulements         Deroulement[]
}

model Plan {
  id       Int    @id @default(autoincrement())
  title    String
  cost     Int
  features Json

  organizations Organization[]
}

model Deroulement {
  id       Int @id @default(autoincrement())

  id_event Int
  event    Event @relation(fields: [id_event], references: [id])

  id_area  Int
  area     Area @relation(fields: [id_area], references: [id])
}