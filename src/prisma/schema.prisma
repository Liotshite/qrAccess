// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  ORG_AGENT
  OPERATOR
}

enum QrStatus {
  active
  revoked
  expired
  used_up
}

enum ScanStatus {
  authorized
  denied_expired
  denied_revoked
  denied_limit_reached
}

//////////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////////

model User {
  id           Int       @id @default(autoincrement())
  clef         String    @unique @default(uuid())
  fullName     String?   @map("full_name")
  email        String    @unique
  passwordHash String?   @map("password_hash")
  role         UserRole
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime? @map("created_at")
  orgId        Int?      @map("org_id")
  createdById  Int?      @map("created_by_id")

  organization Organization? @relation(fields: [orgId], references: [id])
  creator      User?         @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers User[]        @relation("UserCreator")
  events       Event[]
  categories   Category[]

  @@map("users")
}

model Organization {
  id               Int       @id @default(autoincrement())
  name             String?
  createdAt        DateTime? @map("created_at")
  deletedAt        DateTime? @map("deleted_at")
  subscriptionPlan String?   @map("subscription_plan") // free, premium, enterprise

  users User[]

  @@map("organizations")
}

model Event {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  title       String?
  description String?
  categoryId  Int?      @map("categoryId")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  deletedAt   DateTime? @map("deleted_at")

  user      User     @relation(fields: [userId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])
  qrCodes   QrCode[]

  @@map("events")
}

model QrCode {
  id          Int       @id @default(autoincrement())
  eventId     Int       @map("event_id")
  uniqueToken String    @unique @map("unique_token")
  status      QrStatus
  usageLimit  Int       @default(1) @map("usage_limit")
  scansCount  Int       @default(0) @map("scans_count")
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  deletedAt   DateTime? @map("deleted_at")

  event     Event     @relation(fields: [eventId], references: [id])
  scanLogs  ScanLog[]

  @@map("qr_codes")
}

model Category {
  id       Int     @id @default(autoincrement())
  catTitle String? @map("catTitle")
  userId   Int?    @map("userId")

  user   User?  @relation(fields: [userId], references: [id])
  events Event[]

  @@map("category")
}

model ScanLog {
  id           Int       @id @default(autoincrement())
  qrCodeId     Int       @map("qr_code_id")
  scannedAt    DateTime? @map("scanned_at")
  locationLat  Float?    @map("location_lat")
  locationLong Float?    @map("location_long")
  status       ScanStatus

  qrCode QrCode @relation(fields: [qrCodeId], references: [id])

  @@map("scan_logs")
}