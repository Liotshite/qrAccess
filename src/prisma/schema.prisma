// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  ORG_AGENT
  OPERATOR
}

enum QrStatus {
  active
  revoked
  expired
  used_up
}

enum ScanStatus {
  authorized
  denied_expired
  denied_revoked
  denied_limit_reached
}

//////////////////////
// MODELS
//////////////////////

model User {
  user_id            Int        @id @default(autoincrement())
  clef          String     @unique
  full_name     String
  email         String     @unique
  password_hash String
  role          Role
  deleted_at    DateTime?
  created_at    DateTime   @default(now())
  last_login    DateTime?

  org_id        Int?
  organization  Organization? @relation(fields: [org_id], references: [org_id])

  scan_logs     ScanLog[]

  @@map("users")
}

model Organization {
  org_id                  Int       @id @default(autoincrement())
  name                String
  created_at          DateTime  @default(now())
  deleted_at          DateTime?

  subscription_plan   Int?
  plan                Plan?     @relation(fields: [subscription_plan], references: [plan_id])

  users               User[]
  events              Event[]
  areas               Area[]

  @@map("organizations")
}

model Event {
  event_id          Int       @id @default(autoincrement())
  org_id      Int
  title       String
  description String?
  created_at  DateTime  @default(now())
  deleted_at  DateTime?

  organization Organization @relation(fields: [org_id], references: [org_id])
  qr_codes     QrCode[]
  EventSchedules EventSchedule[]

  @@map("events")
}

model QrCode {
  qr_id           Int       @id @default(autoincrement())
  event_id      Int
  information   String?
  unique_token  String    @unique
  status        QrStatus
  usage_limit   Int       @default(1)
  scans_count   Int       @default(0)
  valid_from    DateTime?
  valid_until   DateTime?
  deleted_at    DateTime?
  level         Int?

  event         Event     @relation(fields: [event_id], references: [event_id])
  scan_logs     ScanLog[]

  @@map("qr_codes")
}

model ScanLog {
  id              Int       @id @default(autoincrement())
  qr_code_id      Int
  scanned_by_id   Int
  scanned_at      DateTime  @default(now())
  location_lat    Decimal?
  location_long   Decimal?
  status          ScanStatus

  qr_code         QrCode    @relation(fields: [qr_code_id], references: [qr_id])
  scanned_by      User      @relation(fields: [scanned_by_id], references: [user_id])

  @@map("scan_logs")
}

model Area {
  area_id                   Int    @id @default(autoincrement())
  org_id               Int
  area_name            String
  accreditation_level  Int

  organization         Organization @relation(fields: [org_id], references: [org_id])
  EventSchedules         EventSchedule[]

  @@map("area")
}

model Plan {
  plan_id        Int    @id @default(autoincrement())
  title     String
  cost      Int
  features  Json

  organizations Organization[]

  @@map("plan")
}

model EventSchedule {
  id         Int      @id @default(autoincrement())
  id_event   Int
  id_area    Int
  start_date DateTime
  end_date   DateTime

  event      Event    @relation(fields: [id_event], references: [event_id])
  area       Area     @relation(fields: [id_area], references: [area_id])

  @@map("EventSchedule")
}